*.env.local

# Node
node_modules/
runtime/legacy/node_modules/

# Logs / temp
*.log
*.tmp
_logs/
tmp/

# Pack artifacts
openclaw-hma-v*.zip

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude Code
.claude/

# Desktop app build
apps/desktop/node_modules/
apps/desktop/dist/
apps/desktop/release/
