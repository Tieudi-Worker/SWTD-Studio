{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openclaw-hma.local/schema/brief.schema.json",
  "title": "HMA Brief",
  "description": "Per-SKU brief.json schema. Located at data/<SKU>/brief.json. Auto-generated by hma-research or hand-edited.",
  "type": "object",
  "required": [
    "sku",
    "product_name",
    "category",
    "materials",
    "features",
    "occasion",
    "input_images",
    "dimensions"
  ],
  "properties": {
    "sku": {
      "type": "string",
      "description": "SKU code, e.g. TNTD180326i750",
      "pattern": "^[A-Z0-9]+$"
    },
    "product_name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": [
        "wood_ornament",
        "acrylic_ornament",
        "paper_card",
        "jar",
        "frame",
        "mixed"
      ]
    },
    "materials": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "features": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "occasion": {
      "type": "string",
      "examples": [
        "teacher_gift",
        "mother_day",
        "graduation",
        "wedding",
        "baby",
        "general_gift",
        "christmas",
        "valentine"
      ]
    },
    "input_images": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Relative paths to input/product/*.jpg"
    },
    "dimensions": {
      "type": "string",
      "description": "Human-readable size string, e.g. '4x3 inches, credit-card sized'"
    },

    "usp": { "type": "string" },
    "target_audience": { "type": "string" },
    "color_preference": { "type": "string" },
    "copy_style": {
      "type": "string",
      "enum": ["emotional", "benefit", "playful"]
    },

    "aplus_type": {
      "type": "string",
      "enum": ["single", "multi_asin"]
    },
    "aplus_plan_style": {
      "type": "string",
      "enum": ["A", "B"]
    },
    "ref_catalog": {
      "type": "object",
      "description": "Named ref roles for A+ pipeline",
      "additionalProperties": { "type": "string" }
    },
    "parent_asin_id": { "type": "string" },
    "child_asins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sku", "role", "display_name"],
        "properties": {
          "sku": { "type": "string" },
          "role": { "type": "string" },
          "display_name": { "type": "string" },
          "primary_use_case": { "type": "string" }
        }
      }
    },
    "aplus_product_guards": { "type": "string" },

    "product_structure": { "type": "string" },
    "see_through_cutout_rule": { "type": "string" },
    "critical_structure": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },

    "web_research_merged": { "type": "object" },
    "web_research_source_path": { "type": "string" },
    "knowledge_insights": { "type": "object" },
    "knowledge_photography_tips": { "type": "array" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "aplus_type": { "const": "multi_asin" } },
        "required": ["aplus_type"]
      },
      "then": {
        "required": ["parent_asin_id", "child_asins"]
      }
    }
  ]
}
