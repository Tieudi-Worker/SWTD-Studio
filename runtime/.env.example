# Copy to runtime/.env and fill in.
# .env is gitignored — never commit real keys.

# Required: KIE.ai API key for nano-banana-pro / seedream-4 / kling-3.0
KIE_KEY=sk-replace-me

# Optional: structured logging
LOG_LEVEL=info
# LOG_FILE=D:/AI PROJECT/openclaw-hma/data/_logs/hma.log

# Optional: override path to legacy production code (v0.1 only)
# Defaults to ../../../handmade-media-agent-v0/handmade-media-agent relative to runtime/
# HMA_LEGACY_ROOT=D:/AI PROJECT/handmade-media-agent-v0/handmade-media-agent
