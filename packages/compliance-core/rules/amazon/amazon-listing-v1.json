      "id": "amazon.false-claim.guaranteed-results",
      "category": "false-claim",
      "severity": "block",
      "appliesTo": ["insight-brief", "creative-brief", "prompt", "image-generate", "image-metadata", "export"],
      "predicate": {
        "kind": "containsAnyTokens",
