{
  "name": "swtd-studio",
  "version": "0.1.0",
  "private": true,
  "description": "SWTD Studio — Amazon media production desktop app",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder",
    "lint": "eslint src/ electron/"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.tieudi.swtd-studio",
    "productName": "SWTD Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "../core/src/**/*",
      "../../runtime/**/*",
      "../../_shared/**/*",
      "../../skills/**/*"
    ],
    "extraResources": [
      { "from": "../../runtime", "to": "runtime" },
      { "from": "../../_shared", "to": "_shared" },
      { "from": "../../skills", "to": "skills" }
    ]
  }
}
